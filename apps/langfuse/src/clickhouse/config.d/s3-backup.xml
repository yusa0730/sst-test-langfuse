<clickhouse>
  <storage_configuration>
    <disks>
      <s3_backup>
        <type>s3_plain</type>
        <endpoint>https://sst-test-langfuse-clickhouse-backup-bucket-production.s3.ap-northeast-1.amazonaws.com/</endpoint>
        <use_environment_credentials>true</use_environment_credentials>
      </s3_backup>
    </disks>
  </storage_configuration>

  <backups>
    <allowed_disk>s3_backup</allowed_disk>
  </backups>
</clickhouse>
