<clickhouse>
  <remote_servers>
    <default>
      <shard>
        <internal_replication>true</internal_replication>
        <replica>
          <host>clickhouse-1.langfuse.local</host>
          <port>9000</port>
        </replica>
        <replica>
          <host>clickhouse-2.langfuse.local</host>
          <port>9000</port>
        </replica>
      </shard>
    </default>
  </remote_servers>

  <zookeeper>
    <node>
      <host>clickhouse-keeper-1.langfuse.local</host>
      <port>9181</port>
    </node>
    <node>
      <host>clickhouse-keeper-2.langfuse.local</host>
      <port>9181</port>
    </node>
    <node>
      <host>clickhouse-keeper-3.langfuse.local</host>
      <port>9181</port>
    </node>
  </zookeeper>
</clickhouse>